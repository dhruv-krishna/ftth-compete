# Caddy reverse proxy fronting Reflex's two ports on HF Spaces.
# HF exposes :7860 to the public; we route by path:
#   - WebSocket on /_event → backend :8000 (with explicit WS upgrade
#     headers; Caddy 2 auto-handles WS but being explicit avoids edge
#     cases when the path matcher kicks in after a long URL).
#   - Other backend HTTP endpoints (/_health, /ping, our Plotly HTML
#     endpoints /v2_map_html, /provider_map_html) → :8000
#   - Everything else (HTML/JS/CSS bundle) → frontend :3000

:7860 {
    log {
        output stderr
        format console
        level INFO
    }

    # WebSocket — explicit upgrade headers. flush_interval -1 disables
    # response buffering so server-pushed state mutations reach the
    # browser immediately, and the transport read/write timeouts are
    # raised well above the longest backfill (B2 momentum ~5 min) so
    # the proxy never idle-kills a live event handler.
    @websocket {
        path /_event /_event/*
        header Connection *Upgrade*
        header Upgrade websocket
    }
    handle @websocket {
        reverse_proxy 127.0.0.1:8000 {
            flush_interval -1
            header_up Host {host}
            header_up X-Real-IP {remote_host}
            transport http {
                read_timeout 30m
                write_timeout 30m
                dial_timeout 10s
            }
        }
    }

    # Non-WS backend endpoints (health checks + the Plotly HTML iframes
    # + the private /admin sidecar). Map renders can take 30-60s on a
    # cold market — give granian generous read timeouts so Caddy
    # doesn't return a 504 mid-render.
    @backend path /_event /_event/* /_health /ping /v2_map_html* /provider_map_html* /admin /admin*
    handle @backend {
        reverse_proxy 127.0.0.1:8000 {
            transport http {
                read_timeout 5m
                write_timeout 5m
                dial_timeout 10s
            }
        }
    }

    # Frontend (Next.js export served by Reflex prod-mode static server).
    handle {
        reverse_proxy 127.0.0.1:3000
    }
}
