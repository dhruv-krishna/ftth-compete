.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# Build
dist/
build/
*.egg

# Streamlit
.streamlit/secrets.toml

# Logs (FCC API URLs sometimes contain hash_value tokens — never commit)
*.log

# Generated artifacts / debug dumps
exports/
scripts/_v2_map_test.html
evans_*.json
*_tearsheet.json
*_tearsheet.pdf

# uv lockfile is fine to commit, but exclude any local override
.python-version
