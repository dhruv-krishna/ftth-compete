# Copy to .env and fill in. .env is gitignored — never commit it.

# Census Bureau API key — free, request at https://www.census.gov/data/developers/api-key.html
CENSUS_API_KEY=

# Google Places API (New) key — billing required, but rating lookups stay in 1K free tier with caching.
# Enable Places API (New) in Google Cloud Console.
GOOGLE_PLACES_KEY=

# FCC BDC Public Data API credentials — free, register at https://apps.fcc.gov/cores/userLogin.do
# then generate API token at https://broadbandmap.fcc.gov/. Required for automated BDC downloads.
FCC_USERNAME=
FCC_API_TOKEN=

# RECOMMENDED on Windows + OneDrive: keep heavy stuff outside sync.
# Tells uv to put the venv outside OneDrive. uv reads UV_PROJECT_ENVIRONMENT natively.
UV_PROJECT_ENVIRONMENT=

# Tells the app where to put bulk parquet and the SQLite cache. Defaults to <repo>/data if unset.
FTTH_DATA_DIR=
